From f74590b695ddb74b090ebaca67af3b1d408a08de Mon Sep 17 00:00:00 2001
From: "Vaidya, Mahesh R" <mahesh.r.vaidya@intel.com>
Date: Mon, 4 Aug 2025 13:33:58 -0700
Subject: [PATCH] Reserve system memory required by rootport hw design.

Reserve 0x1000 size space in system memory at 0x9fffff000, required
by the rootport design to handle MSI dummy write requests sent by
MSI ordering module.

Upstream-Status: Pending [Will be submitted soon]
Signed-off-by: Vaidya, Mahesh R <mahesh.r.vaidya@intel.com>
---
 arch/arm64/boot/dts/intel/socfpga_agilex5.dtsi | 5 +++++
 1 file changed, 5 insertions(+)

diff --git a/arch/arm64/boot/dts/intel/socfpga_agilex5.dtsi b/arch/arm64/boot/dts/intel/socfpga_agilex5.dtsi
index 27d2286e6931..65d437900924 100644
--- a/arch/arm64/boot/dts/intel/socfpga_agilex5.dtsi
+++ b/arch/arm64/boot/dts/intel/socfpga_agilex5.dtsi
@@ -26,6 +26,11 @@ service_reserved: svcbuffer@0 {
 			alignment = <0x1000>;
 			no-map;
 		};
+
+		pcie_rootport_buf: pcie-rootport-buf@9fffff000 {
+			reg = <0x00000009 0xfffff000 0x0 0x1000>;
+			no-map;
+		};
 	};
 
 	cpus {
-- 
2.34.1


##### README file - Steps to run simulation for SM (Sundance Mesa) System-Example-Design PCIe Rootport #####

   #I. Get clone and resource (see../README). List again here:
      1. To clone a fresh repository (this step need to do once for new repo)
      % git clone git clone https://github.com/intel-innersource/applications.fpga.system-example-designs.agilex5-ed-pcie-rp.git <myclone_name>

      2. Get resource (do once for new window)
      %arc shell osc_dv/2021WW37 vcs-vcsmx-lic/vrtn-dev,synopsys_dc/R-2020.09-SP3,acdskit-rtl/24.3,avalon_vip/13.1/1,devmain/1.0,devacds/23.4,synopsys_vip_common/vip_Q-2020.03A,p4/psgeng,perl/5.8.8,testutils/23.4,regutils/23.4,itf/23.4,altuvm/0.9p8,synopsys_verdi/R-2020.12-SP2,vcs/R-2020.12-SP2-6,python_altera/2.7.3b/1.0,flow/nb/norm-acds-pipe-dv-rgr,easic_etools/13.3,cygwin/2.9.0


   #II. Run simulation in ITF
      #Run test
      #1. Set working directory and run a test
      %setenv setenv REG_LOCAL_ROOT_DIR_PATH <working directory>
      Example:
      %setenv REG_LOCAL_ROOT_DIR_PATH /nfs/site/disks/swuser_work_susanttr/git_ws2/sm_pcie_rp/applications.fpga.system-example-designs.agilex5-ed-pcie-rp/src/hw/a5e065bb32aes1_pdk/verification

      %cd $REG_LOCAL_ROOT_DIR_PATH/script/itf
      %reg_exe --localr --testname=sysrp_sanity_test --dump_on=1 --seed=123 --uvm_verbosity=UVM_HIGH

      #2. Log and waveform located under $REG_LOCAL_ROOT_DIR_PATH/script/itf
      %cd rtl_sim_compile_only_vcs/sequence/rtl_sim_simulate_only_vcs__s0123/synopsys/vcs
         ...
         symbol.log top_vcs.out trans.log sim.log vcdplus.vpd
         ...

      #3. Clean up files from previous run
         % cd $REG_LOCAL_ROOT_DIR_PATH/script/itf
         %reg_reset

      #
      #Run regression in ITF 
      #
      #1. Set working directory and run a test
      %setenv setenv REG_LOCAL_ROOT_DIR_PATH <working directory>
      Example:
      %setenv REG_LOCAL_ROOT_DIR_PATH /nfs/site/disks/swuser_work_susanttr/git_ws2/sm_pcie_rp/applications.fpga.system-example-designs.agilex5-ed-pcie-rp/src/hw/a5e065bb32aes1_pdk/verification

      %cd $REG_LOCAL_ROOT_DIR_PATH/script/itf

      #2. Update the nightly_regr.sh to your working directory
      Example: 
      %more nightly_regr.sh 
            export REG_LOCAL_ROOT_DIR_PATH=/nfs/site/disks/swuser_work_susanttr/git_ws2/sm_pcie_rp/applications.fpga.system-example-designs.agilex5-ed-pcie-rp/src/hw/a5e065bb32aes1_pdk/verification
            cd $REG_LOCAL_ROOT_DIR_PATH/script/itf
            reg_reset
            reg_exe --farm --regr_cfg=sanity_regr

      #3. Run nightly_regr.sh
          %./nightly_regr.sh



            </ipxact:field>
            <ipxact:field>
              <ipxact:name>ecrc_gen_en</ipxact:name>
              <ipxact:description>ECRC Generation Enable.
When Set, ECRC generation is enabled. Functions that do not implement the associated mechanism are permitted to hardwire this bit to 0b.
Default value of this bit is 0b.
Note: This register field is sticky.</ipxact:description>
              <ipxact:bitOffset>6</ipxact:bitOffset>
              <ipxact:resets>
                <ipxact:reset>
                  <ipxact:value>0x0</ipxact:value>
                  <ipxact:mask>0x1</ipxact:mask>

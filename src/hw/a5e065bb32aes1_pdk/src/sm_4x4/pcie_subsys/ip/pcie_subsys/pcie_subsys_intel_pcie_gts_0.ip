              <ipxact:bitWidth>1</ipxact:bitWidth>
              <ipxact:access>read-only</ipxact:access>
            </ipxact:field>
            <ipxact:field>
              <ipxact:name>ecrc_check_en</ipxact:name>
              <ipxact:description>ECRC Check Enable.
When Set, ECRC checking is enabled. Functions that do not implement the associated mechanism are permitted to hardwire this bit to 0b.
Default value of this bit is 0b.
Note: This register field is sticky.</ipxact:description>
              <ipxact:bitOffset>8</ipxact:bitOffset>

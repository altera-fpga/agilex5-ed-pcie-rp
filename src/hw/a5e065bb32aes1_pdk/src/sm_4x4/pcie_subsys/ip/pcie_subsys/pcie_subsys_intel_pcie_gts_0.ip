            <ipxact:field>
              <ipxact:name>ptm_req_scaled_clock_t_en</ipxact:name>
              <ipxact:description>PTM Requester Scaled Clock Period Enable.
This bit is cleared when the core_clk rate starts to change and can only be set when the clock period change is complete. For more information, see the PTM section in the Databook.
Note: This register field is sticky.</ipxact:description>
              <ipxact:bitOffset>31</ipxact:bitOffset>
              <ipxact:resets>
                <ipxact:reset>
                  <ipxact:value>0x0</ipxact:value>
                  <ipxact:mask>0x1</ipxact:mask>

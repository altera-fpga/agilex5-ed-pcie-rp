              </ipxact:resets>
              <ipxact:bitWidth>8</ipxact:bitWidth>
              <ipxact:access>read-write</ipxact:access>
            </ipxact:field>
            <ipxact:field>
              <ipxact:name>receiver_number_status</ipxact:name>
              <ipxact:description>Receiver Number(Status) for Lane 0.
For Downstream Ports, this field must be reset to the default value if the Port goes to DL_Down status.
</ipxact:description>
              <ipxact:bitOffset>16</ipxact:bitOffset>
              <ipxact:resets>
                <ipxact:reset>
                  <ipxact:value>0x0</ipxact:value>
                  <ipxact:mask>0x7</ipxact:mask>

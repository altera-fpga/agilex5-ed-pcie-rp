          <ipxact:register>
            <ipxact:name>pf0_dlink_cap_data_link_feature_status_off</ipxact:name>
            <ipxact:description>This register provides status of the capability of data link feature.</ipxact:description>
            <ipxact:addressOffset>0x428</ipxact:addressOffset>

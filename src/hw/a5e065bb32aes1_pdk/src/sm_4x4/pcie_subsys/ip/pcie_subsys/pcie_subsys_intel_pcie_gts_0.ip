              <ipxact:description>Byte 3 of Header log register of First 32-bit Data wrd.
This field represents fourth byte of First DW of Header.
Note: This register field is sticky.</ipxact:description>
              <ipxact:bitOffset>24</ipxact:bitOffset>
              <ipxact:resets>
                <ipxact:reset>

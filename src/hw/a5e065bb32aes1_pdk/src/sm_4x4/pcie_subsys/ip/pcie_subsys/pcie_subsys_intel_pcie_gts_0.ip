            <ipxact:description>The Margining Lane Control Register consists of control fields required for per-Lane margining.
The number of entries in this register are sized by Maximum Link Width.</ipxact:description>
            <ipxact:addressOffset>0x1d8</ipxact:addressOffset>
            <ipxact:size>32</ipxact:size>
            <ipxact:access>read-write</ipxact:access>
            <ipxact:field>
              <ipxact:name>receiver_number</ipxact:name>

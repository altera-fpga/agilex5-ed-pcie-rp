                </ipxact:reset>
              </ipxact:resets>
              <ipxact:bitWidth>5</ipxact:bitWidth>
              <ipxact:access>read-only</ipxact:access>
            </ipxact:field>
            <ipxact:field>
              <ipxact:name>ecrc_gen_cap</ipxact:name>
              <ipxact:description>ECRC Generation Capable.
If Set, this bit indicates that the Function is capable of generating ECRC.
Note: This register field is sticky.</ipxact:description>
              <ipxact:bitOffset>5</ipxact:bitOffset>
              <ipxact:resets>
                <ipxact:reset>

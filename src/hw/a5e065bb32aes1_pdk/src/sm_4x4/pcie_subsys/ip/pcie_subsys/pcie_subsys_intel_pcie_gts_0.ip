              <ipxact:name>margin_type_status</ipxact:name>
              <ipxact:description>Margin Type(Status) for Lane 0.
This field must be reset to the default value if the Port goes to DL_Down status.
</ipxact:description>
              <ipxact:bitOffset>19</ipxact:bitOffset>
              <ipxact:resets>
                <ipxact:reset>
                  <ipxact:value>0x0</ipxact:value>
                  <ipxact:mask>0x7</ipxact:mask>
                </ipxact:reset>
              </ipxact:resets>
              <ipxact:bitWidth>3</ipxact:bitWidth>
              <ipxact:access>read-only</ipxact:access>
            </ipxact:field>
            <ipxact:field>
              <ipxact:name>usage_model_status</ipxact:name>
              <ipxact:description>Usage Model(Status) for Lane 0.
This field must be reset to the default value if the Port goes to DL_Down status.
</ipxact:description>
              <ipxact:bitOffset>22</ipxact:bitOffset>

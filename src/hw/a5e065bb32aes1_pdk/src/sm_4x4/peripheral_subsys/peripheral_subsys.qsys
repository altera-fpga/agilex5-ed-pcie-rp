                        &lt;value&gt;0xacd5cafe&lt;/value&gt;
                    &lt;/entry&gt;
                &lt;/cmsisVars&gt;
            &lt;/cmsisInfo&gt;
        &lt;/interface&gt;
    &lt;/interfaces&gt;
&lt;/boundaryDefinition&gt;</ipxact:value>

          <ipxact:value>bonusData 
{
   element interrupt_latency_counter
   {
      datum _sortIndex
      {
         value = "3";
         type = "int";
      }
   }
   element interrupt_latency_counter.avalon_slave
   {
      datum baseAddress
      {
         value = "4352";
         type = "String";
      }
   }
   element pb_cpu_0
